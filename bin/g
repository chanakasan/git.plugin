#!/bin/bash

source $nx_git_root/src/includes/git.sh

_g () {
  local base=$nx_git_root
  if [[ -z "$1" ]]; then
    _g_prompt
  else
    _g_try $1
  fi
}

_g_prompt() {
  local value
  read -p "g: " value
  if [[ -n $value ]]; then
    _g_try $value
  fi
}

_g_try() {
  local fn=g-$1
  if [[ $(type -t $fn ) == function ]]; then
    $fn "${@:2}"
  else
    git "$@"
  fi
}

source_files() {
  if [ -z "$nx_git_root" ]; then
    export nx_git_root=$HOME/nex-git
  fi
  . $nx_git_root/src/bash/main.sh
}

_g "$@"