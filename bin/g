#!/bin/bash

source $nx_git_root/src/elements/git.sh

main() {
  local a1="$1"
  local a2="$2"
  local fn=g-$a1
  if [ -z "$a1" ]; then
    git status
  elif [[ $(type -t $fn ) == function ]]; then
    $fn "${@:2}"
  else
    git "$@"
  fi
}

source_files() {
  if [ -z "$nx_git_root" ]; then
    export nx_git_root=$HOME/nex-git
  fi
  . $nx_git_root/src/bash/main.sh
}

# _end_
main "$@"